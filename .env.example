# GitHub App credentials (create at https://github.com/settings/apps)
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...paste your .pem contents here...
-----END RSA PRIVATE KEY-----"

# Webhook secret (set the same value in your GitHub App webhook config)
GH_WEBHOOK_SECRET=your-webhook-secret-here

# Groq LLM settings
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=60

# Agent settings
LOG_LEVEL=INFO
MAX_DIFF_LINES=500
