# GitHub App credentials (create at https://github.com/settings/apps)
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...paste your .pem contents here...
-----END RSA PRIVATE KEY-----"

# Webhook secret (set the same value in your GitHub App webhook config)
GH_WEBHOOK_SECRET=your-webhook-secret-here

# Groq LLM settings
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=60

# Agent settings
LOG_LEVEL=INFO
MAX_DIFF_LINES=500

# GitHub OAuth (for dashboard login — create at https://github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=your-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Session signing key (generate a random 32+ char string)
SESSION_SECRET_KEY=change-me-to-a-random-secret

# Dashboard settings
FRONTEND_URL=http://localhost:8504/dashboard/
PUBLIC_BASE_URL=http://localhost:8501
CONFIG_DB_PATH=/app/data/config.db
